{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HeThongDieuTraAnNinhMang",
  "version": "0.1.0",
  "identifier": "vn.agency.cyberinvest",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5173"
  },
  "app": {
    "windows": [
      {
        "title": "Hệ thống điều tra sự cố an ninh mạng",
        "width": 1280,
        "height": 840,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "wix": {
        "language": "vi-VN"
      }
    }
  }
}
